# DataForSEO — https://dataforseo.com
DATAFORSEO_LOGIN=tu-email@dominio.com
DATAFORSEO_PASSWORD=tu-password

# Google Search Console (path al JSON de service account)
GSC_CREDENTIALS=/ruta/a/tu/gsc-credentials.json

# PageSpeed Insights — https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=tu-api-key

# Google Analytics (analytics-mcp)
GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/tu/application_default_credentials.json

# Microsoft Clarity — un token por proyecto/cliente
# El nombre de la variable debe seguir el patrón: CLARITY_TOKEN_{NOMBRE_PROYECTO}
# Ejemplos:
CLARITY_TOKEN_NOMBRE_PROYECTO=tu-clarity-api-token
# CLARITY_TOKEN_OTRO_PROYECTO=otro-token

# Ruta donde se guardan los reportes (opcional — ver README)
SEO_REPORTS_PATH=/ruta/a/tu/carpeta/reports
